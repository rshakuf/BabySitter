<UserControl x:Class="BabySitter.KidInfoControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">

    <Border Background="White" CornerRadius="16" Padding="16" Margin="8" Width="220">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08"/>
        </Border.Effect>

        <StackPanel>

            <!-- Title -->
            <TextBlock x:Name="CardTitle"
                       Text="ילד חדש"
                       FontSize="15" FontWeight="Bold"
                       Foreground="#6750A4"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>

            <!-- First name -->
            <TextBlock Text="שם פרטי" FontSize="11" Foreground="#49454F" Margin="2,0,0,3"/>
            <Border Background="#F7F2FA" CornerRadius="8" Height="36" Margin="0,0,0,8">
                <TextBox x:Name="FirstNameTextBox"
                         Background="Transparent" BorderThickness="0"
                         VerticalContentAlignment="Center" Padding="10,0"
                         FontSize="14" Foreground="#1C1B1F"/>
            </Border>

            <!-- Last name -->
            <TextBlock Text="שם משפחה" FontSize="11" Foreground="#49454F" Margin="2,0,0,3"/>
            <Border Background="#F7F2FA" CornerRadius="8" Height="36" Margin="0,0,0,8">
                <TextBox x:Name="LastNameTextBox"
                         Background="Transparent" BorderThickness="0"
                         VerticalContentAlignment="Center" Padding="10,0"
                         FontSize="14" Foreground="#1C1B1F"/>
            </Border>

            <!-- Birth date -->
            <TextBlock Text="תאריך לידה" FontSize="11" Foreground="#49454F" Margin="2,0,0,3"/>
            <DatePicker x:Name="BirthDatePicker"
                        Height="36" Margin="0,0,0,8"
                        FontSize="13"/>

            <!-- City -->
            <TextBlock Text="עיר" FontSize="11" Foreground="#49454F" Margin="2,0,0,3"/>
            <ComboBox x:Name="CityComboBox"
                      Height="36" Margin="0,0,0,14"
                      FontSize="13"
                      DisplayMemberPath="CityName"/>

            <!-- Save button -->
            <Button x:Name="SaveBtn"
                    Content="שמור"
                    Height="36"
                    Background="#6750A4" Foreground="White"
                    FontSize="13" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand"
                    Click="SaveKid_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="18"/>
                    </Style>
                </Button.Resources>
            </Button>

            <!-- Messages -->
            <TextBlock x:Name="ErrorText"
                       Text="" Foreground="#C53030"
                       FontSize="12" Visibility="Collapsed"
                       HorizontalAlignment="Center" Margin="0,6,0,0"
                       TextWrapping="Wrap"/>

            <TextBlock x:Name="SavedText"
                       Text="נשמר ✓" Foreground="#2E7D32"
                       FontSize="12" Visibility="Collapsed"
                       HorizontalAlignment="Center" Margin="0,6,0,0"/>

        </StackPanel>
    </Border>
</UserControl>
