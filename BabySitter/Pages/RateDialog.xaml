<Window x:Class="BabySitter.Pages.RateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="480" Height="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <!-- Chip-style toggle for CheckBox -->
        <Style x:Key="ChipCheckBox" TargetType="CheckBox">
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="chip"
                                Background="#EDE7F6" CornerRadius="16"
                                Padding="14,6" BorderThickness="0">
                            <TextBlock x:Name="lbl"
                                       Text="{TemplateBinding Content}"
                                       FontSize="13"
                                       Foreground="#6750A4"
                                       FontWeight="SemiBold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="chip" Property="Background" Value="#6750A4"/>
                                <Setter TargetName="lbl"  Property="Foreground"  Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="chip" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="6" Opacity="0.18" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#6750A4" CornerRadius="20,20,0,0" Padding="24,16">
                <Grid>
                    <TextBlock x:Name="TitleText"
                               FontSize="18" FontWeight="Bold" Foreground="White"
                               VerticalAlignment="Center"/>
                    <Button Content="✕"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Background="Transparent" Foreground="White"
                            FontSize="16" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand"
                            Width="32" Height="32"
                            Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="28,20,28,24">

                    <TextBlock Text="כמה כוכבים מגיע לבייביסיטר?"
                               FontSize="13" Foreground="#49454F"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>

                    <!-- Stars -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,22">
                        <TextBlock x:Name="S1" Text="★" FontSize="44" Cursor="Hand" Margin="4,0"
                                   Foreground="#CCCCCC" MouseLeftButtonDown="Star_Click" Tag="1"/>
                        <TextBlock x:Name="S2" Text="★" FontSize="44" Cursor="Hand" Margin="4,0"
                                   Foreground="#CCCCCC" MouseLeftButtonDown="Star_Click" Tag="2"/>
                        <TextBlock x:Name="S3" Text="★" FontSize="44" Cursor="Hand" Margin="4,0"
                                   Foreground="#CCCCCC" MouseLeftButtonDown="Star_Click" Tag="3"/>
                        <TextBlock x:Name="S4" Text="★" FontSize="44" Cursor="Hand" Margin="4,0"
                                   Foreground="#CCCCCC" MouseLeftButtonDown="Star_Click" Tag="4"/>
                        <TextBlock x:Name="S5" Text="★" FontSize="44" Cursor="Hand" Margin="4,0"
                                   Foreground="#CCCCCC" MouseLeftButtonDown="Star_Click" Tag="5"/>
                    </StackPanel>

                    <!-- Tags -->
                    <TextBlock Text="תגיות (בחר את המתאימות):"
                               FontSize="13" FontWeight="SemiBold" Foreground="#49454F"
                               Margin="0,0,0,10"/>
                    <WrapPanel Margin="0,0,0,20">
                        <CheckBox x:Name="TagReliable"  Content="אמין"    Style="{StaticResource ChipCheckBox}"/>
                        <CheckBox x:Name="TagPatient"   Content="סבלן"    Style="{StaticResource ChipCheckBox}"/>
                        <CheckBox x:Name="TagCreative"  Content="יצירתי"  Style="{StaticResource ChipCheckBox}"/>
                        <CheckBox x:Name="TagPro"       Content="מקצועי"  Style="{StaticResource ChipCheckBox}"/>
                        <CheckBox x:Name="TagDedicated" Content="מסור"    Style="{StaticResource ChipCheckBox}"/>
                        <CheckBox x:Name="TagNice"      Content="נחמד"    Style="{StaticResource ChipCheckBox}"/>
                        <CheckBox x:Name="TagResp"      Content="אחראי"   Style="{StaticResource ChipCheckBox}"/>
                        <CheckBox x:Name="TagInterest"  Content="מעניין"  Style="{StaticResource ChipCheckBox}"/>
                    </WrapPanel>

                    <!-- Free-text review -->
                    <TextBlock Text="ביקורת חופשית (רשות):"
                               FontSize="13" FontWeight="SemiBold" Foreground="#49454F"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="ReviewTextBox"
                             Height="80" TextWrapping="Wrap"
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                             FontSize="13" Padding="10"
                             BorderBrush="#CAC4D0" BorderThickness="1"
                             Background="#FAFAFA" Margin="0,0,0,24">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- Submit -->
                    <Button x:Name="SubmitBtn"
                            Content="שלח דירוג ★"
                            Height="46" Width="180"
                            HorizontalAlignment="Center"
                            IsEnabled="False"
                            Click="Submit_Click"
                            Background="#6750A4" Foreground="White"
                            FontSize="14" FontWeight="Bold" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="23"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
