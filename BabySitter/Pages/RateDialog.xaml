<Window x:Class="BabySitter.Pages.RateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="דירוג בייביסיטר"
        Width="460" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FFFBFE"
        FlowDirection="RightToLeft">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,24">

            <!-- Title -->
            <TextBlock x:Name="TitleText"
                       FontSize="18" FontWeight="Bold" Foreground="#1C1B1F"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock Text="כמה כוכבים מגיע לבייביסיטר?"
                       FontSize="13" Foreground="#49454F"
                       HorizontalAlignment="Center" Margin="0,0,0,18"/>

            <!-- Stars row -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,22">
                <TextBlock x:Name="S1" Text="★" FontSize="42" Cursor="Hand" Margin="4,0"
                           Foreground="#CCCCCC" MouseLeftButtonDown="Star_Click" Tag="1"/>
                <TextBlock x:Name="S2" Text="★" FontSize="42" Cursor="Hand" Margin="4,0"
                           Foreground="#CCCCCC" MouseLeftButtonDown="Star_Click" Tag="2"/>
                <TextBlock x:Name="S3" Text="★" FontSize="42" Cursor="Hand" Margin="4,0"
                           Foreground="#CCCCCC" MouseLeftButtonDown="Star_Click" Tag="3"/>
                <TextBlock x:Name="S4" Text="★" FontSize="42" Cursor="Hand" Margin="4,0"
                           Foreground="#CCCCCC" MouseLeftButtonDown="Star_Click" Tag="4"/>
                <TextBlock x:Name="S5" Text="★" FontSize="42" Cursor="Hand" Margin="4,0"
                           Foreground="#CCCCCC" MouseLeftButtonDown="Star_Click" Tag="5"/>
            </StackPanel>

            <!-- Tags section -->
            <TextBlock Text="תגיות (בחר את המתאימות):"
                       FontSize="13" FontWeight="SemiBold" Foreground="#49454F"
                       Margin="0,0,0,10"/>
            <WrapPanel Margin="0,0,0,18">
                <CheckBox x:Name="TagReliable"  Content="אמין"    Margin="6,4" FontSize="13"/>
                <CheckBox x:Name="TagPatient"   Content="סבלן"    Margin="6,4" FontSize="13"/>
                <CheckBox x:Name="TagCreative"  Content="יצירתי"  Margin="6,4" FontSize="13"/>
                <CheckBox x:Name="TagPro"       Content="מקצועי"  Margin="6,4" FontSize="13"/>
                <CheckBox x:Name="TagDedicated" Content="מסור"    Margin="6,4" FontSize="13"/>
                <CheckBox x:Name="TagNice"      Content="נחמד"    Margin="6,4" FontSize="13"/>
                <CheckBox x:Name="TagResp"      Content="אחראי"   Margin="6,4" FontSize="13"/>
                <CheckBox x:Name="TagInterest"  Content="מעניין"  Margin="6,4" FontSize="13"/>
            </WrapPanel>

            <!-- Free-text review -->
            <TextBlock Text="ביקורת חופשית (רשות):"
                       FontSize="13" FontWeight="SemiBold" Foreground="#49454F"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="ReviewTextBox"
                     Height="80" TextWrapping="Wrap"
                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                     FontSize="13" Padding="8"
                     BorderBrush="#CAC4D0" BorderThickness="1"
                     Background="White" Margin="0,0,0,22"/>

            <!-- Submit button -->
            <Button x:Name="SubmitBtn"
                    Content="שלח דירוג"
                    Height="44" Width="160"
                    HorizontalAlignment="Center"
                    IsEnabled="False"
                    Click="Submit_Click"
                    Background="#6750A4" Foreground="White"
                    FontSize="14" FontWeight="SemiBold" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="22"/>
                    </Style>
                </Button.Resources>
            </Button>

        </StackPanel>
    </ScrollViewer>
</Window>
