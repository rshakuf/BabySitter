<Page x:Class="BabySitter.Pages.Home"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:BabySitter"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      Title="Home"
      Background="#F7F2FA" 
      FlowDirection="RightToLeft"
      d:DesignHeight="720" d:DesignWidth="1280"
      mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="MaterialComboBoxM3" TargetType="ComboBox">
            <Setter Property="Height" Value="56"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#ECE6F0"/>
            <Setter Property="BorderBrush" Value="#49454F"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="MainBorder" Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4,4,0,0"/>
                            <DockPanel Margin="{TemplateBinding Padding}">
                                <Path x:Name="Arrow" DockPanel.Dock="Left" Fill="#49454F" Data="M 0 0 L 4 4 L 8 0 Z" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" 
                                                  Content="{TemplateBinding SelectionBoxItem}" 
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" VerticalAlignment="Center"/>
                            </DockPanel>
                            <ToggleButton Opacity="0" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder" Background="#F7F2FA" BorderBrush="#CAC4D0" BorderThickness="1" CornerRadius="8" Margin="0,2,0,0" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#E6E0E9"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderThickness" Value="0,0,0,2"/>
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#6750A4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Border Margin="20" Background="#FFFBFE" CornerRadius="28">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.1"/>
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ROW 0: Header -->
            <DockPanel Grid.Row="0" Margin="0,0,0,30">
                <StackPanel>
                    <TextBlock Text="חיפוש בייביסיטר"
                               FontSize="34" FontWeight="Bold" Foreground="#1C1B1F"/>
                    <TextBlock Text="מצאו את השמרטף המושלם"
                               FontSize="16" Foreground="#49454F" Margin="2,5,0,0"/>
                    <TextBlock x:Name="WelcomeText"
                               FontSize="18" Foreground="#6750A4" FontWeight="SemiBold" Margin="0,8,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="הפניות שלי" Style="{StaticResource MaterialTonalButton}" Margin="0,0,12,0" Click="MyRequests"/>
                    <Button Content="הפרופיל שלי"
        Style="{StaticResource MaterialFilledButton}"
        Click="GoToMyProfile"/>
                </StackPanel>
            </DockPanel>

            <!-- ROW 1: Filters -->
            <Grid Grid.Row="1" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <!-- Search with placeholder overlay + clear button -->
                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="חיפוש חופשי" FontSize="12" Foreground="#6750A4" FontWeight="Bold" Margin="5,0,0,5"/>
                    <Grid>
                        <!-- Placeholder overlay (replaces GotFocus/LostFocus hack) -->
                        <TextBlock Text="🔍  חפש לפי שם..."
                                   Foreground="#9E9E9E" FontSize="14"
                                   VerticalAlignment="Center" Margin="20,0,0,0"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Search TextBox -->
                        <TextBox x:Name="SearchBox"
                                 Style="{StaticResource MaterialTextBox}"
                                 Height="56"
                                 Padding="16,0,44,0"
                                 TextChanged="SearchBox_TextChanged"/>

                        <!-- Clear button -->
                        <Button x:Name="ClearSearchBtn"
                                Content="✕" Width="32" Height="32"
                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                Margin="6,0,0,0"
                                Visibility="Collapsed"
                                Click="ClearSearch_Click"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#49454F" FontSize="14" Cursor="Hand"/>
                    </Grid>
                </StackPanel>

                <!-- City filter -->
                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                    <TextBlock Text="עיר" FontSize="12" Foreground="#6750A4" FontWeight="Bold" Margin="5,0,0,5"/>
                    <ComboBox x:Name="CityComboBox" Style="{StaticResource MaterialComboBoxM3}"
                              SelectionChanged="FilterChanged"/>
                </StackPanel>

                <!-- Sort -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="מיון לפי" FontSize="12" Foreground="#6750A4" FontWeight="Bold" Margin="5,0,0,5"/>
                    <ComboBox x:Name="SortComboBox" Style="{StaticResource MaterialComboBoxM3}"
                              SelectionChanged="FilterChanged">
                        <ComboBoxItem Content="ללא מיון" IsSelected="True"/>
                        <ComboBoxItem Content="מחיר: מהזול ליקר"/>
                        <ComboBoxItem Content="מחיר: מהיקר לזול"/>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- ROW 2: Results area with loading / empty / list states -->
            <Grid Grid.Row="2">

                <!-- Loading state -->
                <StackPanel x:Name="LoadingPanel"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="טוען נתונים..." FontSize="18" Foreground="#6750A4"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Empty state -->
                <StackPanel x:Name="EmptyPanel"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="🔍" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="לא נמצאו בייביסיטרים" FontSize="18" Foreground="#49454F"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock Text="נסו לשנות את הסינון" FontSize="14" Foreground="#79747E"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Results list -->
                <ScrollViewer x:Name="ResultsScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              Visibility="Collapsed">
                    <ItemsControl x:Name="BabysittersItems">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Right"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="12" CornerRadius="16" Background="White">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05"/>
                                    </Border.Effect>
                                    <local:UserControlHome DataContext="{Binding}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>
        </Grid>
    </Border>
</Page>