<Page x:Class="BabySitter.Pages.RequestsParents"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F7F2FA"
      FlowDirection="RightToLeft"
      Title="הבקשות שלי">

    <Border Margin="20" Background="#FFFBFE" CornerRadius="28">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.1"/>
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" Margin="0,0,0,24">
                <Button Content="חזרה"
                        Click="BackButton_Click"
                        Style="{StaticResource MaterialTonalButton}"
                        DockPanel.Dock="Left"
                        Margin="0,0,16,0"/>
                <StackPanel>
                    <TextBlock Text="הבקשות שלי"
                               FontSize="32" FontWeight="Bold" Foreground="#1C1B1F"/>
                    <TextBlock Text="כאן תוכלו לראות את מצב הבקשות שנשלחו"
                               FontSize="14" Foreground="#49454F" Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>

            <!-- Legend -->
            <WrapPanel Grid.Row="1" Margin="0,0,0,20">
                <Border Background="#FFE082" CornerRadius="12" Padding="12,5" Margin="0,0,10,0">
                    <TextBlock Text="⏳  ממתין לאישור" FontSize="12" FontWeight="SemiBold"/>
                </Border>
                <Border Background="#A5D6A7" CornerRadius="12" Padding="12,5" Margin="0,0,10,0">
                    <TextBlock Text="✓  אושר" FontSize="12" FontWeight="SemiBold"/>
                </Border>
                <Border Background="#EF9A9A" CornerRadius="12" Padding="12,5">
                    <TextBlock Text="✗  נדחה" FontSize="12" FontWeight="SemiBold"/>
                </Border>
            </WrapPanel>

            <!-- Content area: loading / empty / list -->
            <Grid Grid.Row="2">

                <StackPanel x:Name="LoadingPanel"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="טוען בקשות..."
                               FontSize="18" Foreground="#6750A4"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <StackPanel x:Name="EmptyPanel"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="📭" FontSize="52" HorizontalAlignment="Center"/>
                    <TextBlock Text="אין בקשות עדיין"
                               FontSize="18" Foreground="#49454F"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock Text="לחצו על 'לפרטים נוספים' אצל בייביסיטר כלשהו כדי לשלוח בקשה"
                               FontSize="13" Foreground="#79747E"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <ScrollViewer x:Name="RequestsScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              Visibility="Collapsed">
                    <StackPanel x:Name="RequestsPanel" Margin="0,4,0,4"/>
                </ScrollViewer>

            </Grid>
        </Grid>
    </Border>
</Page>
