<Page x:Class="BabySitter.Pages.BabysitterHome"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="BabysitterHome"
      Background="#F7F2FA"
      FlowDirection="RightToLeft"
      d:DesignHeight="720" d:DesignWidth="1280">

    <Page.Resources>
        <Style x:Key="SlotButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6C63FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#574BFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Border Margin="20" Background="#FFFBFE" CornerRadius="28">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.1"/>
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ROW 0: Header -->
            <DockPanel Grid.Row="0" Margin="0,0,0,30">
                <StackPanel>
                    <TextBlock Text="האזור האישי שלי"
                               FontSize="34" FontWeight="Bold" Foreground="#1C1B1F"/>
                    <TextBlock x:Name="WelcomeText"
                               FontSize="18" Foreground="#6750A4" FontWeight="SemiBold" Margin="0,8,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="הפרופיל שלי" Style="{StaticResource MaterialFilledButton}"
                            Click="MyProfile_Click"/>
                </StackPanel>
            </DockPanel>

            <!-- ROW 1: Stacked sections -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Section 1: Available slots + add form -->
                    <TextBlock Text="שעות פניות שלי"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#2D3748" Margin="5,0,0,14"/>

                    <StackPanel x:Name="FreeLoadingPanel" Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,6,0,14" Visibility="Collapsed">
                        <StackPanel.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="FDot1" Storyboard.TargetProperty="Y"
                                                         From="0" To="-8" Duration="0:0:0.4" AutoReverse="True" BeginTime="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="FDot2" Storyboard.TargetProperty="Y"
                                                         From="0" To="-8" Duration="0:0:0.4" AutoReverse="True" BeginTime="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="FDot3" Storyboard.TargetProperty="Y"
                                                         From="0" To="-8" Duration="0:0:0.4" AutoReverse="True" BeginTime="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </StackPanel.Triggers>
                        <Ellipse Width="10" Height="10" Fill="#6750A4" Margin="4,0">
                            <Ellipse.RenderTransform><TranslateTransform x:Name="FDot1"/></Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse Width="10" Height="10" Fill="#6750A4" Margin="4,0">
                            <Ellipse.RenderTransform><TranslateTransform x:Name="FDot2"/></Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse Width="10" Height="10" Fill="#6750A4" Margin="4,0">
                            <Ellipse.RenderTransform><TranslateTransform x:Name="FDot3"/></Ellipse.RenderTransform>
                        </Ellipse>
                    </StackPanel>

                    <StackPanel x:Name="ScheduleSlotsPanel" Margin="0,0,0,14"/>

                    <Border Background="#F0EDFF" CornerRadius="14" Padding="16" Margin="0,0,0,30">
                        <StackPanel>
                            <TextBlock Text="הוסף שעה פנויה חדשה"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#4A5568" Margin="0,0,0,12"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="תאריך" FontSize="11"
                                               Foreground="#4A5568" Margin="0,0,0,4"/>
                                    <DatePicker x:Name="NewSlotDate" FontSize="13" Height="36"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="שעת התחלה" FontSize="11"
                                               Foreground="#4A5568" Margin="0,0,0,4"/>
                                    <Border Background="White" CornerRadius="8" Height="36">
                                        <TextBox x:Name="NewSlotStart" Text="09:00"
                                                 FontSize="13" BorderThickness="0"
                                                 VerticalContentAlignment="Center"
                                                 Padding="10,0" Background="Transparent"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="שעת סיום" FontSize="11"
                                               Foreground="#4A5568" Margin="0,0,0,4"/>
                                    <Border Background="White" CornerRadius="8" Height="36">
                                        <TextBox x:Name="NewSlotEnd" Text="17:00"
                                                 FontSize="13" BorderThickness="0"
                                                 VerticalContentAlignment="Center"
                                                 Padding="10,0" Background="Transparent"/>
                                    </Border>
                                </StackPanel>

                                <Button x:Name="AddSlotBtn"
                                        Grid.Column="6"
                                        Content="+ הוסף משמרת"
                                        Click="AddSlot_Click"
                                        Style="{StaticResource SlotButtonStyle}"
                                        Height="36" Width="150"
                                        VerticalAlignment="Bottom"/>
                            </Grid>

                            <TextBlock x:Name="SlotErrorMsg" Text=""
                                       Foreground="#C53030" FontSize="12"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Section 2: Approved slots -->
                    <TextBlock Text="שעות מאושרות"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#2D3748" Margin="5,0,0,14"/>

                    <StackPanel x:Name="ApprovedLoadingPanel" Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,6,0,20" Visibility="Collapsed">
                        <StackPanel.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="ADot1" Storyboard.TargetProperty="Y"
                                                         From="0" To="-8" Duration="0:0:0.4" AutoReverse="True" BeginTime="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="ADot2" Storyboard.TargetProperty="Y"
                                                         From="0" To="-8" Duration="0:0:0.4" AutoReverse="True" BeginTime="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="ADot3" Storyboard.TargetProperty="Y"
                                                         From="0" To="-8" Duration="0:0:0.4" AutoReverse="True" BeginTime="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </StackPanel.Triggers>
                        <Ellipse Width="10" Height="10" Fill="#6750A4" Margin="4,0">
                            <Ellipse.RenderTransform><TranslateTransform x:Name="ADot1"/></Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse Width="10" Height="10" Fill="#6750A4" Margin="4,0">
                            <Ellipse.RenderTransform><TranslateTransform x:Name="ADot2"/></Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse Width="10" Height="10" Fill="#6750A4" Margin="4,0">
                            <Ellipse.RenderTransform><TranslateTransform x:Name="ADot3"/></Ellipse.RenderTransform>
                        </Ellipse>
                    </StackPanel>

                    <StackPanel x:Name="ApprovedSlotsPanel" Margin="0,0,0,30"/>

                    <!-- Section 3: Pending requests -->
                    <TextBlock Text="בקשות ממתינות לאישור"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#2D3748" Margin="5,0,0,14"/>

                    <StackPanel x:Name="PendingLoadingPanel" Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,6,0,20" Visibility="Collapsed">
                        <StackPanel.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="PDot1" Storyboard.TargetProperty="Y"
                                                         From="0" To="-8" Duration="0:0:0.4" AutoReverse="True" BeginTime="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="PDot2" Storyboard.TargetProperty="Y"
                                                         From="0" To="-8" Duration="0:0:0.4" AutoReverse="True" BeginTime="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="PDot3" Storyboard.TargetProperty="Y"
                                                         From="0" To="-8" Duration="0:0:0.4" AutoReverse="True" BeginTime="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </StackPanel.Triggers>
                        <Ellipse Width="10" Height="10" Fill="#6750A4" Margin="4,0">
                            <Ellipse.RenderTransform><TranslateTransform x:Name="PDot1"/></Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse Width="10" Height="10" Fill="#6750A4" Margin="4,0">
                            <Ellipse.RenderTransform><TranslateTransform x:Name="PDot2"/></Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse Width="10" Height="10" Fill="#6750A4" Margin="4,0">
                            <Ellipse.RenderTransform><TranslateTransform x:Name="PDot3"/></Ellipse.RenderTransform>
                        </Ellipse>
                    </StackPanel>

                    <StackPanel x:Name="PendingRequestsPanel" Margin="0,0,0,20"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Page>
