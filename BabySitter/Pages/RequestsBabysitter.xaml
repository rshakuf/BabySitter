<Page x:Class="BabySitter.Pages.RequestsBabysitter"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F7F2FA"
      FlowDirection="RightToLeft"
      Title="בקשות שהתקבלו">

    <Border Margin="20" Background="#FFFBFE" CornerRadius="28">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.1"/>
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" Margin="0,0,0,24">
                <Button Content="חזרה"
                        Click="BackButton_Click"
                        Style="{StaticResource MaterialTonalButton}"
                        DockPanel.Dock="Left"
                        Margin="0,0,16,0"/>
                <StackPanel>
                    <TextBlock Text="בקשות שהתקבלו"
                               FontSize="32" FontWeight="Bold" Foreground="#1C1B1F"/>
                    <TextBlock Text="אשרו או דחו בקשות מהורים"
                               FontSize="14" Foreground="#49454F" Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>

            <!-- Content area: loading / empty / list -->
            <Grid Grid.Row="1">

                <StackPanel x:Name="LoadingPanel"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="טוען בקשות..."
                               FontSize="18" Foreground="#6750A4"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <StackPanel x:Name="EmptyPanel"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="📭" FontSize="52" HorizontalAlignment="Center"/>
                    <TextBlock Text="אין בקשות ממתינות"
                               FontSize="18" Foreground="#49454F"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock Text="כאשר הורה ישלח לך בקשה היא תופיע כאן"
                               FontSize="13" Foreground="#79747E"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <ScrollViewer x:Name="RequestsScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              Visibility="Collapsed">
                    <StackPanel x:Name="RequestsPanel" Margin="0,4,0,4"/>
                </ScrollViewer>

            </Grid>
        </Grid>
    </Border>
</Page>
