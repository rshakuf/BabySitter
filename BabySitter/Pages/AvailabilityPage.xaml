<Page x:Class="BabySitter.Pages.AvailabilityPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F7F2FA"
      FlowDirection="RightToLeft"
      Title="זמינות">

    <Page.Resources>
        <Style x:Key="NavPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="Background" Value="#EDE7F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ROW 0: Babysitter header + profile details -->
        <Border Grid.Row="0" Background="White" CornerRadius="18" Padding="20,14" Margin="0,0,0,14">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.07"/>
            </Border.Effect>
            <StackPanel>

                <!-- Top row: avatar · name · city · price · phone · rating · back -->
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid Width="54" Height="54" Margin="0,0,14,0">
                            <Ellipse Width="54" Height="54" Fill="#6750A4"/>
                            <TextBlock x:Name="AvatarLetter" Foreground="White" FontSize="24"
                                       FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse x:Name="AvatarImageEllipse" Width="54" Height="54" Visibility="Collapsed">
                                <Ellipse.Fill>
                                    <ImageBrush x:Name="AvatarImageBrush" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="BabysitterNameLabel" FontSize="20" FontWeight="Bold" Foreground="#1C1B1F"/>
                            <TextBlock x:Name="BabysitterCityLabel" FontSize="13" Foreground="#49454F"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Button Content="חזרה" Click="BackButton_Click"
                                Height="36" Padding="20,0" Margin="0,0,10,0"
                                Background="#EDE9FF" Foreground="#6750A4"
                                FontSize="14" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="18"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Border Background="#E8DEF8" CornerRadius="10" Padding="12,6" Margin="0,0,10,0">
                            <TextBlock x:Name="BabysitterPriceLabel" FontSize="14" FontWeight="Bold" Foreground="#21005D"/>
                        </Border>
                        <Border Background="#F3E5F5" CornerRadius="10" Padding="12,6" Margin="0,0,10,0">
                            <TextBlock x:Name="BabysitterPhoneLabel" FontSize="13" Foreground="#4A148C"/>
                        </Border>
                        <!-- Average rating — shown after data loads -->
                        <Border x:Name="AvgRatingChip" Background="#FFF8E1" CornerRadius="10"
                                Padding="10,6" Margin="0,0,6,0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="AvgS1" Text="★" FontSize="16" Margin="1,0" Foreground="#CCCCCC"/>
                                <TextBlock x:Name="AvgS2" Text="★" FontSize="16" Margin="1,0" Foreground="#CCCCCC"/>
                                <TextBlock x:Name="AvgS3" Text="★" FontSize="16" Margin="1,0" Foreground="#CCCCCC"/>
                                <TextBlock x:Name="AvgS4" Text="★" FontSize="16" Margin="1,0" Foreground="#CCCCCC"/>
                                <TextBlock x:Name="AvgS5" Text="★" FontSize="16" Margin="1,0" Foreground="#CCCCCC"/>
                                <TextBlock x:Name="AvgRatingText"
                                           FontSize="12" Foreground="#795548"
                                           VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <!-- "See reviews" link — shown when there are ratings -->
                        <TextBlock x:Name="SeeReviewsLink"
                                   Text="ראה ביקורות"
                                   FontSize="12" Foreground="#6750A4"
                                   TextDecorations="Underline"
                                   Cursor="Hand"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   Visibility="Collapsed"
                                   MouseLeftButtonUp="SeeReviews_Click"/>
                    </StackPanel>
                </DockPanel>

                <!-- Divider -->
                <Border Height="1" Background="#EDE7F6" Margin="0,12,0,10"/>

                <!-- Profile details chips -->
                <WrapPanel Orientation="Horizontal">

                    <!-- Age -->
                    <Border Background="#EDE7F6" CornerRadius="20" Padding="12,5" Margin="0,0,8,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎂 " FontSize="12"/>
                            <TextBlock x:Name="BabysitterAgeLabel"
                                       FontSize="12" Foreground="#49454F"/>
                        </StackPanel>
                    </Border>

                    <!-- Email — hidden when empty -->
                    <Border x:Name="MailChip" Background="#E8F5E9" CornerRadius="20"
                            Padding="12,5" Margin="0,0,8,4" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✉ " FontSize="12" Foreground="#2E7D32"/>
                            <TextBlock x:Name="BabysitterMailLabel"
                                       FontSize="12" Foreground="#2E7D32"/>
                        </StackPanel>
                    </Border>

                </WrapPanel>

            </StackPanel>
        </Border>

        <!-- ROW 1: 3-column day view -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="130"/>
            </Grid.ColumnDefinitions>

            <!-- Prev date panel -->
            <Border x:Name="PrevPanel" Grid.Column="2" Style="{StaticResource NavPanelStyle}"
                    MouseLeftButtonUp="PrevDate_Click">
                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <TextBlock Text="→" FontSize="18" HorizontalAlignment="Center"
                               Foreground="#6750A4" Margin="0,0,0,6"/>
                    <TextBlock x:Name="PrevDateLabel" FontSize="13" FontWeight="SemiBold"
                               Foreground="#49454F" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Current day panel -->
            <Border Grid.Column="1" Background="White" CornerRadius="20" Margin="4,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.09"/>
                </Border.Effect>
                <Grid Margin="20,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="CurrentDateLabel" Grid.Row="0"
                               FontSize="18" FontWeight="Bold" Foreground="#1C1B1F"
                               HorizontalAlignment="Center" Margin="0,0,0,14"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="HourSlotsPanel"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Next date panel -->
            <Border x:Name="NextPanel" Grid.Column="0" Style="{StaticResource NavPanelStyle}"
                    MouseLeftButtonUp="NextDate_Click">
                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <TextBlock Text="←" FontSize="18" HorizontalAlignment="Center"
                               Foreground="#6750A4" Margin="0,0,0,6"/>
                    <TextBlock x:Name="NextDateLabel" FontSize="13" FontWeight="SemiBold"
                               Foreground="#49454F" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ROW 2: Legend + send button -->
        <Border Grid.Row="2" Background="White" CornerRadius="16" Padding="20,12" Margin="0,14,0,0">
            <DockPanel>
                <!-- Legend -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <Border Background="#A5D6A7" CornerRadius="8" Padding="10,4" Margin="0,0,8,0">
                        <TextBlock Text="פנוי" FontSize="12"/>
                    </Border>
                    <Border Background="#EF9A9A" CornerRadius="8" Padding="10,4" Margin="0,0,8,0">
                        <TextBlock Text="תפוס" FontSize="12"/>
                    </Border>
                    <Border Background="#FFF176" CornerRadius="8" Padding="10,4" Margin="0,0,8,0" BorderBrush="#F9A825" BorderThickness="1">
                        <TextBlock Text="נבחר" FontSize="12"/>
                    </Border>
                    <Border Background="#EEEEEE" CornerRadius="8" Padding="10,4">
                        <TextBlock Text="עבר" FontSize="12" Foreground="#BDBDBD"/>
                    </Border>
                </StackPanel>

                <!-- Send button + summary -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock x:Name="SelectionSummary" FontSize="13" Foreground="#6750A4"
                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button x:Name="SendRequestBtn"
                            Content="שלח בקשה ✉"
                            Height="42" Padding="24,0"
                            Background="#6750A4" Foreground="White"
                            FontSize="14" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand"
                            IsEnabled="False"
                            Click="SendRequest_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="21"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Loading overlay -->
        <Border x:Name="LoadingOverlay" Grid.Row="1" Background="#80FFFFFF"
                CornerRadius="20" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="טוען זמינות..." FontSize="16" Foreground="#6750A4"
                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
