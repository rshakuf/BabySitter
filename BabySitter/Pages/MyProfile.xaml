<Page x:Class="BabySitter.Pages.MyProfile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1280"
      Title="MyProfile"
      FlowDirection="RightToLeft">

    <Page.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="40" ShadowDepth="10" Color="#30000000" Opacity="0.15"/>
        <DropShadowEffect x:Key="InputShadow" BlurRadius="10" ShadowDepth="3" Color="#20000000" Opacity="0.1"/>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6C63FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="12" 
                                Effect="{StaticResource InputShadow}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#574BFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F3E7E9" Offset="0"/>
            <GradientStop Color="#E3EEFF" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <Grid>
        <Border Width="650" 
                VerticalAlignment="Center" 
                Background="#D9FFFFFF" 
                CornerRadius="25" 
                Margin="40" 
                Padding="40"
                Effect="{StaticResource CardShadow}">

            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="-10" Padding="10">
                <StackPanel>

                    <TextBlock Text="הפרופיל שלי"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="#2D3748"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Profile picture (babysitter only) -->
                    <StackPanel x:Name="AvatarSection" HorizontalAlignment="Center"
                                Margin="0,0,0,24" Visibility="Collapsed">
                        <Grid Width="100" Height="100" Cursor="Hand"
                              MouseLeftButtonUp="PickProfilePic_Click"
                              ToolTip="לחץ לשינוי תמונת פרופיל">
                            <!-- background circle -->
                            <Ellipse Width="100" Height="100" Fill="#6C63FF"/>
                            <!-- letter fallback -->
                            <TextBlock x:Name="AvatarLetterProfile"
                                       FontSize="38" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <!-- photo overlay (shown when picture exists) -->
                            <Ellipse x:Name="AvatarImageEllipseProfile" Width="100" Height="100"
                                     Visibility="Collapsed">
                                <Ellipse.Fill>
                                    <ImageBrush x:Name="AvatarImageBrushProfile" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <!-- camera badge -->
                            <Border Width="32" Height="32" CornerRadius="16"
                                    Background="#6C63FF" BorderBrush="White" BorderThickness="2"
                                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                    Margin="2,0,0,2">
                                <TextBlock Text="📷" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="לחץ לשינוי תמונה"
                                   FontSize="12" Foreground="#718096"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="שם פרטי" Foreground="#4A5568" FontWeight="SemiBold" Margin="5,0,0,5"/>
                            <Border Background="White" CornerRadius="12" Height="45" Effect="{StaticResource InputShadow}">
                                <TextBox x:Name="fname" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="15,0" FontSize="16" Foreground="#2D3748"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="שם משפחה" Foreground="#4A5568" FontWeight="SemiBold" Margin="5,0,0,5"/>
                            <Border Background="White" CornerRadius="12" Height="45" Effect="{StaticResource InputShadow}">
                                <TextBox x:Name="lname" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="15,0" FontSize="16" Foreground="#2D3748"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Email + Price row (babysitter only) -->
                    <Grid x:Name="EmailPriceSection" Margin="0,0,0,15" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>

                        <!-- Email -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="מייל" Foreground="#4A5568" FontWeight="SemiBold" Margin="5,0,0,5"/>
                            <Border Background="White" CornerRadius="12" Height="45" Effect="{StaticResource InputShadow}">
                                <TextBox x:Name="mail" Background="Transparent" BorderThickness="0"
                                         VerticalContentAlignment="Center" Padding="15,0" FontSize="16"
                                         Foreground="#2D3748"
                                         LostFocus="Mail_LostFocus"
                                         TextChanged="Mail_TextChanged"/>
                            </Border>
                            <TextBlock x:Name="MailErrorMsg" Text="" Foreground="#C53030"
                                       FontSize="12" Margin="5,3,0,0" Visibility="Collapsed"/>
                        </StackPanel>

                        <!-- Price per hour -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="מחיר לשעה (₪)" Foreground="#4A5568" FontWeight="SemiBold" Margin="5,0,0,5"/>
                            <Border Background="White" CornerRadius="12" Height="45" Effect="{StaticResource InputShadow}">
                                <Grid>
                                    <TextBlock Text="₪" FontSize="16" Foreground="#9E9E9E"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,12,0" IsHitTestVisible="False"/>
                                    <TextBox x:Name="pricePerHour"
                                             Background="Transparent" BorderThickness="0"
                                             VerticalContentAlignment="Center" Padding="15,0,30,0"
                                             FontSize="16" Foreground="#2D3748"
                                             PreviewTextInput="Price_PreviewTextInput"
                                             MaxLength="5"/>
                                </Grid>
                            </Border>
                            <TextBlock x:Name="PriceErrorMsg" Text="" Foreground="#C53030"
                                       FontSize="12" Margin="5,3,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="טלפון" Foreground="#4A5568" FontWeight="SemiBold" Margin="5,0,0,5"/>
                            <Border Background="White" CornerRadius="12" Height="45" Effect="{StaticResource InputShadow}">
                                <TextBox x:Name="phone" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="15,0" FontSize="16" Foreground="#2D3748"
                                         PreviewTextInput="Phone_PreviewTextInput" MaxLength="10"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="עיר" Foreground="#4A5568" FontWeight="SemiBold" Margin="5,0,0,5"/>
                            <Border Background="White" CornerRadius="12" Height="45" Effect="{StaticResource InputShadow}">
                                <ComboBox x:Name="cityComboBox" 
                  Background="Transparent" 
                  BorderThickness="0" 
                  VerticalContentAlignment="Center" 
                  Padding="10,0" 
                  FontSize="16" 
                  Foreground="#2D3748"
                  DisplayMemberPath="CityName" />
                            </Border>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,25">
                        <TextBlock Text="סיסמה" Foreground="#4A5568" FontWeight="SemiBold" Margin="5,0,0,5"/>
                        <Border Background="White" CornerRadius="12" Height="45" Effect="{StaticResource InputShadow}">
                            <Grid>
                                <PasswordBox x:Name="pass" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="15,0,45,0" FontSize="16" Foreground="#2D3748"/>
                                <TextBox x:Name="passVisible" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="15,0,45,0" FontSize="16" Foreground="#2D3748" Visibility="Collapsed"/>

                                <TextBlock Text="👁" 
                                           HorizontalAlignment="Left" 
                                           VerticalAlignment="Center" 
                                           Margin="15,0,0,0"
                                           Cursor="Hand" 
                                           FontSize="18" 
                                           Foreground="#A0AEC0" 
                                           ToolTip="הצג/הסתר סיסמה"
                                           MouseDown="TogglePassword"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="KidsSection" Margin="0,0,0,30">
                        <TextBlock Text="הילדים שלי"
               FontSize="20"
               FontWeight="Bold"
               Foreground="#2D3748"
               Margin="5,0,0,10"/>

                        <Border Background="#40FFFFFF"
            CornerRadius="15"
            Padding="15">

                            <WrapPanel x:Name="KidsPanel"/>
                        </Border>

                        <!-- Add kid button -->
                        <Button Content="+ הוסף ילד"
                                Click="AddKid_Click"
                                Height="38"
                                Width="160"
                                HorizontalAlignment="Center"
                                Margin="0,12,0,0"
                                Background="#EDE9FF"
                                Foreground="#6750A4"
                                FontSize="14"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="19"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                    <Button x:Name="SaveBtn"
                            Content="שמור שינויים"
                            Click="SaveChanges"
                            Style="{StaticResource ModernButtonStyle}"
                            Height="50"
                            Width="200"
                            HorizontalAlignment="Center"/>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>