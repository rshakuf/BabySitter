<Page x:Class="BabySitter.Pages.JobHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="JobHistoryPage"
      Background="#F7F2FA"
      FlowDirection="RightToLeft"
      d:DesignHeight="720" d:DesignWidth="1280">

    <Border Margin="20" Background="#FFFBFE" CornerRadius="28">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.1"/>
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="היסטוריית עבודה"
                               FontSize="34" FontWeight="Bold" Foreground="#1C1B1F"/>
                    <TextBlock x:Name="SubtitleText"
                               FontSize="16" Foreground="#49454F" Margin="2,5,0,0"/>
                </StackPanel>
                <Button Content="חזרה"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Style="{StaticResource MaterialTonalButton}"
                        Click="Back_Click"/>
            </DockPanel>

            <!-- Summary bar -->
            <Border Grid.Row="1" Background="#F3EDF7" CornerRadius="16" Padding="20,14" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,40,0">
                        <TextBlock x:Name="TotalJobsText" FontSize="26" FontWeight="Bold" Foreground="#6750A4"/>
                        <TextBlock Text="משמרות בסך הכל" FontSize="13" Foreground="#49454F"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,40,0">
                        <TextBlock x:Name="TotalHoursText" FontSize="26" FontWeight="Bold" Foreground="#6750A4"/>
                        <TextBlock Text="שעות עבודה" FontSize="13" Foreground="#49454F"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock x:Name="LastJobText" FontSize="20" FontWeight="Bold" Foreground="#6750A4"/>
                        <TextBlock Text="תאריך משמרת אחרונה" FontSize="13" Foreground="#49454F"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Content area -->
            <Grid Grid.Row="2">

                <!-- Loading -->
                <StackPanel x:Name="LoadingPanel"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Visible">
                    <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="טוען היסטוריה..." FontSize="18" Foreground="#6750A4"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Empty -->
                <StackPanel x:Name="EmptyPanel"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="📋" FontSize="56" HorizontalAlignment="Center"/>
                    <TextBlock Text="אין היסטוריית עבודה עדיין"
                               FontSize="20" Foreground="#49454F" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <TextBlock Text="משמרות שעברו יופיעו כאן"
                               FontSize="14" Foreground="#79747E"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- List -->
                <ScrollViewer x:Name="ListScroll" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel x:Name="HistoryPanel"/>
                </ScrollViewer>

            </Grid>
        </Grid>
    </Border>
</Page>
