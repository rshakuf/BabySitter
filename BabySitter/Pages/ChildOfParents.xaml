<Page x:Class="BabySitter.Pages.ChildOfParents"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="פרטי הילדים"
      Background="#F4F7FC"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Padding="40,30,40,30" CornerRadius="0,0,30,30" Margin="0,0,0,20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#667EEA" Offset="0.0"/>
                    <GradientStop Color="#764BA2" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <StackPanel HorizontalAlignment="Right">
                    <TextBlock Text="פרטי הילדים" FontSize="32" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="הזן את פרטי הילדים שלך ולחץ על סיום" FontSize="15" Foreground="#E2E8F0" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- KIDS LIST -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <WrapPanel x:Name="KidsContainer"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       Margin="20,0,20,20"/>
        </ScrollViewer>

        <!-- BOTTOM AREA -->
        <Border Grid.Row="2" Padding="20,16">
            <StackPanel HorizontalAlignment="Center">

                <!-- Error message -->
                <TextBlock x:Name="ErrorText"
                           Text="יש להזין לפחות ילד אחד"
                           Foreground="#C53030"
                           FontSize="14"
                           Visibility="Collapsed"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <!-- Add another child -->
                <Button Content="+ הוסף ילד"
                        Click="AddKid_Click"
                        Width="160" Height="40"
                        FontSize="14" FontWeight="SemiBold"
                        Foreground="#6750A4" Background="#EDE9FF"
                        BorderThickness="0" Cursor="Hand"
                        Margin="0,0,0,10">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="20"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <!-- Finish / Save -->
                <Button x:Name="FinishBtn"
                        Content="שמור וסיים הרשמה"
                        Width="240" Height="50"
                        FontSize="17" FontWeight="Bold"
                        Foreground="White" Background="#667EEA"
                        BorderThickness="0" Cursor="Hand"
                        Click="FinishRegistration">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="25"/>
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </Border>

    </Grid>
</Page>
