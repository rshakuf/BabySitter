<Page x:Class="BabySitter.Pages.ChildOfParents"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Children Profiles" 
      Background="#F4F7FC" 
      FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Padding="40,30,40,40" CornerRadius="0,0,30,30" Margin="0,0,0,20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#667EEA" Offset="0.0" />
                    <GradientStop Color="#764BA2" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel>
                <TextBlock Text="Children Profiles" FontSize="36" FontWeight="Bold" Foreground="White" />
                <TextBlock Text="Manage and update details for the kids in your care." FontSize="16" Foreground="#E2E8F0" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- KIDS LIST -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <WrapPanel x:Name="KidsContainer"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       Margin="20,0,20,40"/>
        </ScrollViewer>

        <!-- FINISH AREA -->
        <Border Grid.Row="2" Padding="20">
            <StackPanel HorizontalAlignment="Center">

                <!-- הודעת שגיאה -->
                <TextBlock x:Name="ErrorText"
                           Text="לא הזנת ילד"
                           Foreground="Red"
                           FontSize="16"
                           Visibility="Collapsed"
                           Margin="0,0,0,10"
                           HorizontalAlignment="Center"/>

                <Button Content="סיום הרשמה"
                        Width="220"
                        Height="50"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="White"
                        Background="#667EEA"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="FinishRegistration">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="25"/>
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </Border>

    </Grid>
</Page>