<Page x:Class="BabySitter.Pages.ParentPaymentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="היסטוריית תשלומים"
      Background="#F7F2FA"
      FlowDirection="RightToLeft">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ROW 0: Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center">
                <Button Content="חזרה" Click="Back_Click"
                        Height="36" Padding="20,0"
                        Background="#EDE9FF" Foreground="#6750A4"
                        FontSize="14" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="18"/></Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="היסטוריית תשלומים" FontSize="30" FontWeight="Bold" Foreground="#1C1B1F"/>
                <TextBlock Text="סיכום הוצאות לפי בייביסיטר" FontSize="14" Foreground="#49454F" Margin="0,4,0,0"/>
            </StackPanel>
        </DockPanel>

        <!-- ROW 1: Summary totals -->
        <Border Grid.Row="1" Background="#EDE9FF" CornerRadius="16" Padding="20,14" Margin="0,0,0,20">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="💳" FontSize="32"/>
                </StackPanel>
                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="סה&quot;כ הוצאות" FontSize="13" Foreground="#49454F" FontWeight="Medium"/>
                    <TextBlock x:Name="TotalAmountText" Text="₪0" FontSize="26" FontWeight="Bold" Foreground="#6750A4"/>
                </StackPanel>
                <Border Width="1" Background="#C4B8EE" Margin="20,4,20,4"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="משמרות שהושלמו" FontSize="13" Foreground="#49454F" FontWeight="Medium"/>
                    <TextBlock x:Name="TotalJobsText" Text="0" FontSize="26" FontWeight="Bold" Foreground="#1C1B1F"/>
                </StackPanel>
                <Border Width="1" Background="#C4B8EE" Margin="20,4,20,4"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="בייביסיטרים שונים" FontSize="13" Foreground="#49454F" FontWeight="Medium"/>
                    <TextBlock x:Name="TotalSittersText" Text="0" FontSize="26" FontWeight="Bold" Foreground="#1C1B1F"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ROW 2: List of babysitters -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Loading -->
                <StackPanel x:Name="LoadingPanel" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Margin="0,60,0,0"
                            Visibility="Visible">
                    <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="טוען נתונים..." FontSize="18" Foreground="#6750A4"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Empty state -->
                <StackPanel x:Name="EmptyPanel" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Margin="0,60,0,0"
                            Visibility="Collapsed">
                    <TextBlock Text="💰" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="אין עדיין משמרות שהושלמו" FontSize="18" Foreground="#49454F"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Babysitter payment cards -->
                <StackPanel x:Name="PaymentsPanel" Visibility="Collapsed"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
