<UserControl x:Class="BabySitter.UserControls.BabySitterDetailsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="650"
             Width="700"
             FlowDirection="RightToLeft">

    <Border Background="#F7F2FA"
            CornerRadius="28"
            Margin="10">

        <Grid Margin="30">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,25">

                <Border Width="80"
                        Height="80"
                        Background="#6750A4"
                        CornerRadius="40">

                    <TextBlock Text="{Binding FirstName[0]}"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Border>

                <StackPanel VerticalAlignment="Center"
                            Margin="20,0,0,0">

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding FirstName}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#1C1B1F"/>

                        <TextBlock Text="{Binding LastName}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#1C1B1F"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <TextBlock Text="{Binding CityNameId.CityName}"
                               FontSize="16"
                               Foreground="#49454F"/>
                </StackPanel>
            </StackPanel>

            <!-- DETAILS -->
            <UniformGrid Grid.Row="1"
                         Columns="2"
                         Margin="0,0,0,20">

                <Border Background="White"
                        CornerRadius="16"
                        Margin="5"
                        Padding="20">

                    <StackPanel>
                        <TextBlock Text="פרטים כלליים"
                                   FontWeight="Bold"
                                   Foreground="#6750A4"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="תאריך לידה:"
                                   FontSize="12"
                                   Foreground="#49454F"/>

                        <TextBlock Text="{Binding DateOfBirth, StringFormat={}{0:dd/MM/yyyy}}"
                                   FontSize="15"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="מחיר מבוקש:"
                                   FontSize="12"
                                   Foreground="#49454F"/>

                        <TextBlock Text="{Binding PriceForAnHour, StringFormat=₪{0} לשעה}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#00B894"/>
                    </StackPanel>
                </Border>

                <Border Background="White"
                        CornerRadius="16"
                        Margin="5"
                        Padding="20">

                    <StackPanel>
                        <TextBlock Text="יצירת קשר"
                                   FontWeight="Bold"
                                   Foreground="#6750A4"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="מספר טלפון:"
                                   FontSize="12"
                                   Foreground="#49454F"/>

                        <TextBlock Text="{Binding Telephone}"
                                   FontSize="15"
                                   Margin="0,0,0,10"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="מייל ממליץ:"
                                   FontSize="12"
                                   Foreground="#49454F"/>

                        <TextBlock Text="{Binding MailOfRecommender}"
                                   FontSize="14"
                                   Foreground="#1D192B"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- SCHEDULE -->
            <Border Grid.Row="2"
                    Background="White"
                    CornerRadius="16"
                    Padding="20"
                    Margin="0,0,0,20">

                <StackPanel>

                    <TextBlock Text="זמינות לבחירה"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#6750A4"
                               Margin="0,0,0,15"/>

                    <WrapPanel x:Name="SchedulePanel"/>

                    <TextBlock x:Name="SuccessMessage"
                               Text=""
                               Foreground="Green"
                               FontWeight="Bold"
                               Margin="0,15,0,0"
                               FontSize="14"/>
                </StackPanel>
            </Border>

            <!-- BUTTONS -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Button Content="סגור חלון"
                        Width="150"
                        Height="45"
                        Margin="10,0"
                        Background="#6750A4"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Click="CloseButton_Click"/>

                <Button x:Name="SendRequestButton"
                        Content="שלח בקשה"
                        Width="150"
                        Height="45"
                        Margin="10,0"
                        Background="#E53935"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="SendRequestButton_Click"/>
            </StackPanel>

        </Grid>
    </Border>
</UserControl>