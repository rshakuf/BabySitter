<UserControl x:Class="BabySitter.UserControls.BabySitterDetailsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             FlowDirection="RightToLeft">

    <Border Background="#F7F2FA" CornerRadius="28" Margin="10">

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- header      -->
                    <RowDefinition Height="Auto"/>  <!-- details     -->
                    <RowDefinition Height="Auto"/>  <!-- schedule    -->
                    <RowDefinition Height="Auto"/>  <!-- form        -->
                    <RowDefinition Height="Auto"/>  <!-- buttons     -->
                </Grid.RowDefinitions>

                <!-- ── ROW 0 · HEADER ─────────────────────────────────── -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,22">
                    <Grid Width="72" Height="72">
                        <Ellipse Width="72" Height="72" Fill="#6750A4"/>
                        <TextBlock x:Name="DetailAvatarLetter"
                                   Foreground="White" FontSize="30" FontWeight="Bold"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Ellipse x:Name="DetailAvatarImage" Width="72" Height="72" Visibility="Collapsed">
                            <Ellipse.Fill>
                                <ImageBrush x:Name="DetailAvatarBrush" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>
                    <StackPanel VerticalAlignment="Center" Margin="18,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding FirstName}"
                                       FontSize="28" FontWeight="Bold" Foreground="#1C1B1F"/>
                            <TextBlock Text="{Binding LastName}"
                                       FontSize="28" FontWeight="Bold" Foreground="#1C1B1F"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding CityNameId.CityName}"
                                   FontSize="15" Foreground="#49454F"/>
                    </StackPanel>
                </StackPanel>

                <!-- ── ROW 1 · DETAILS ────────────────────────────────── -->
                <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,18">

                    <Border Background="White" CornerRadius="14" Margin="0,0,6,0" Padding="18">
                        <StackPanel>
                            <TextBlock Text="פרטים כלליים"
                                       FontWeight="Bold" Foreground="#6750A4" Margin="0,0,0,10"/>
                            <TextBlock Text="תאריך לידה:" FontSize="12" Foreground="#49454F"/>
                            <TextBlock Text="{Binding DateOfBirth, StringFormat={}{0:dd/MM/yyyy}}"
                                       FontSize="14" Margin="0,2,0,10"/>
                            <TextBlock Text="מחיר מבוקש:" FontSize="12" Foreground="#49454F"/>
                            <TextBlock Text="{Binding PriceForAnHour, StringFormat=₪{0} לשעה}"
                                       FontSize="17" FontWeight="Bold" Foreground="#00B894"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="14" Margin="6,0,0,0" Padding="18">
                        <StackPanel>
                            <TextBlock Text="יצירת קשר"
                                       FontWeight="Bold" Foreground="#6750A4" Margin="0,0,0,10"/>
                            <TextBlock Text="מספר טלפון:" FontSize="12" Foreground="#49454F"/>
                            <TextBlock Text="{Binding Telephone}"
                                       FontSize="14" Margin="0,2,0,10" FontWeight="SemiBold"/>
                            <TextBlock Text="מייל ממליץ:" FontSize="12" Foreground="#49454F"/>
                            <TextBlock Text="{Binding MailOfRecommender}"
                                       FontSize="13" Foreground="#1D192B" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- ── ROW 2 · SCHEDULE AVAILABILITY ─────────────────── -->
                <Border Grid.Row="2"
                        Background="White" CornerRadius="14"
                        Padding="20" Margin="0,0,0,18">
                    <StackPanel>

                        <TextBlock Text="שעות פנויות של הבייביסיטר"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="#6750A4" Margin="0,0,0,6"/>

                        <TextBlock Text="לחץ על משמרת כדי למלא את הטופס אוטומטית"
                                   FontSize="12" Foreground="#79747E" Margin="0,0,0,12"/>

                        <!-- Legend -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Background="White" BorderBrush="#CAC4D0" BorderThickness="1"
                                    CornerRadius="8" Padding="8,3" Margin="0,0,8,0">
                                <TextBlock Text="פנוי — ניתן לבחור" FontSize="11" Foreground="#49454F"/>
                            </Border>
                            <Border Background="#FFE082" CornerRadius="8" Padding="8,3" Margin="0,0,8,0">
                                <TextBlock Text="יש בקשה ממתינה" FontSize="11"/>
                            </Border>
                            <Border Background="#A5D6A7" CornerRadius="8" Padding="8,3">
                                <TextBlock Text="מאושר" FontSize="11"/>
                            </Border>
                        </StackPanel>

                        <TextBlock x:Name="NoSlotsMessage"
                                   Text="אין זמינות רשומה כרגע"
                                   FontSize="14" Foreground="#79747E"
                                   Visibility="Collapsed"/>

                        <WrapPanel x:Name="SchedulePanel"/>

                    </StackPanel>
                </Border>

                <!-- ── ROW 3 · REQUEST FORM ───────────────────────────── -->
                <Border Grid.Row="3"
                        Background="White" CornerRadius="14"
                        Padding="22" Margin="0,0,0,18">
                    <StackPanel>

                        <TextBlock Text="שלח בקשה לבייביסיטר"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="#6750A4" Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="תאריך מבוקש"
                                           FontSize="12" Foreground="#49454F" Margin="0,0,0,5"/>
                                <DatePicker x:Name="RequestDatePicker"
                                            FirstDayOfWeek="Sunday"
                                            SelectedDateFormat="Short"
                                            FontSize="14" Height="40"
                                            DisplayDateStart="{x:Static system:DateTime.Today}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="שעת התחלה"
                                           FontSize="12" Foreground="#49454F" Margin="0,0,0,5"/>
                                <TextBox x:Name="StartTimeBox"
                                         Text="09:00"
                                         FontSize="14" Height="40" Padding="10,0"
                                         Style="{StaticResource MaterialTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="מספר שעות"
                                           FontSize="12" Foreground="#49454F" Margin="0,0,0,5"/>
                                <ComboBox x:Name="HoursComboBox"
                                          FontSize="14" Height="40"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="3"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="5"/>
                                    <ComboBoxItem Content="6"/>
                                    <ComboBoxItem Content="7"/>
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="9"/>
                                    <ComboBoxItem Content="10"/>
                                    <ComboBoxItem Content="11"/>
                                    <ComboBoxItem Content="12"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock x:Name="FormErrorMessage"
                                   Text="" Foreground="#B71C1C"
                                   FontSize="13" Margin="0,10,0,0"/>

                    </StackPanel>
                </Border>

                <!-- ── ROW 4 · BUTTONS ────────────────────────────────── -->
                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,10">

                    <Button Content="סגור"
                            Width="140" Height="44" Margin="10,0"
                            Background="#E8E0F0" Foreground="#1D192B"
                            FontSize="15" FontWeight="SemiBold"
                            BorderThickness="0"
                            Click="CloseButton_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="22"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button x:Name="SendRequestButton"
                            Content="שלח בקשה ✉"
                            Width="175" Height="44" Margin="10,0"
                            Background="#6750A4" Foreground="White"
                            FontSize="15" FontWeight="Bold"
                            BorderThickness="0"
                            Click="SendRequestButton_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="22"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                </StackPanel>

            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
